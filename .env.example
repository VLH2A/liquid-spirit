# Kilo gateway (OpenAI-compatible)
KILO_BASE_URL=your_gateway_base_url_here
KILO_API_KEY=your_key_here
# Model id — must be vision-capable to read menu photos
KILO_MODEL=your_model_here

# Example (local Ollama via Kilo, text-only — no menu vision):
#   KILO_BASE_URL=http://172.26.64.1:11434/v1
#   KILO_API_KEY=ollama
#   KILO_MODEL=qwen3:14b
